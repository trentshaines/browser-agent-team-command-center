# Copy to .env and fill in values
# cp env.example .env

# Database (Neon Postgres) — swap postgresql:// for postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname?ssl=require

# Auth
SECRET_KEY=your-secret-key-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback/google

# LLM_PROVIDER=bedrock

# Claude / LLM
ANTHROPIC_API_KEY=your-anthropic-key
OPENROUTER_API_KEY=your-openrouter-key
BROWSER_AGENT_MODEL=google/gemini-2.0-flash-001

# AWS Bedrock (set LLM_PROVIDER=bedrock to use Bedrock for the orchestrator SDK)
# AWS_BEARER_TOKEN_BEDROCK=ABSK...your-bedrock-api-key
# AWS_REGION=us-east-1
# ANTHROPIC_MODEL=us.anthropic.claude-sonnet-4-6
# ANTHROPIC_SMALL_FAST_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0

# App
FRONTEND_URL=http://localhost:5173
ENVIRONMENT=development

# Internal API (shared secret between backend and browser agent subprocess)
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_TOKEN=your-internal-api-token

# Observability
# SENTRY_DSN=https://...@sentry.io/...

# Production cookie settings (set these in Railway)
# COOKIE_SECURE=true
# COOKIE_SAMESITE=none
